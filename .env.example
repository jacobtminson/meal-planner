# Copy this to .env and fill in your values

# Mealie
MEALIE_URL=http://localhost:9000
MEALIE_TOKEN=your-mealie-api-token-here

# Spoonacular (https://spoonacular.com/food-api)
SPOONACULAR_KEY=your-spoonacular-api-key-here

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Email (SMTP) — Gmail example; use an App Password, not your account password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-here

# User emails
JACOB_EMAIL=jacob@example.com
WIFE_EMAIL=wife@example.com

# Public URL of the swipe app (used in notification emails)
APP_BASE_URL=https://meals.yourdomain.com
